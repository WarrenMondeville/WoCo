<Project>
  <PropertyGroup>
    <LangVersion>11.0</LangVersion>
    <NoWarn>0169,0649,3021,8981</NoWarn>
    <DebugType>Portable</DebugType>
  </PropertyGroup>
  <ItemGroup Condition="'$(MSBuildProjectName)' != 'Share.SourceGenerator' And '$(MSBuildProjectName)' != 'Share.Analyzer'">
    <Analyzer Include="$(MSBuildThisFileDirectory)Assets\Plugins\Share.SourceGenerator.dll" />
  </ItemGroup>
</Project>